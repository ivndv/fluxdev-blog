---
/**
 * Layout para entradas individuales del blog con metadata, interacción y navegación.
 */

import Comments from "../components/Comments.jsx";
import ShareButtons from "../components/ShareButtons.astro";
import { useTranslations } from "../i18n/ui";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

// Detecta idioma desde la URL: asume estructura "/[lang]/..." o "/" para español por defecto.
// Nota: Si la estructura de rutas cambia, esta lógica debe actualizarse.
const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] === "en" ? "en" : "es";
const t = useTranslations(lang);
---

<Layout
    title={frontmatter.title}
    description={frontmatter.description}
    type="article"
    publishDate={frontmatter.date}
    lang={lang}
>
    <article
        class="prose prose-stone dark:prose-invert prose-base md:prose-lg mx-auto mt-6 mb-12 md:mt-10 md:mb-20 animate-fade-in-up"
    >
        {
            /* Enlace de navegación: regresar al listado de posts del idioma actual */
        }
        <div class="mb-6">
            <a
                href={`/${lang === "es" ? "" : lang}`}
                class="no-underline inline-flex items-center gap-2 text-sm font-bold text-text-muted hover:text-accent transition-colors group"
            >
                <span
                    class="icon-[solar--alt-arrow-left-outline] w-4 h-4 group-hover:-translate-x-1 transition-transform"
                ></span>
                {t("blog.back")}
            </a>
        </div>

        {/* Cabecera del artículo: título, metadata y etiquetas */}
        <div class="mb-8 border-b border-border-subtle pb-6">
            <h1
                class="mb-4 text-3xl md:text-4xl font-extrabold text-text-primary leading-tight"
            >
                {frontmatter.title}
            </h1>

            <div class="flex flex-wrap items-center gap-4 mb-4">
                {/* Fecha de publicación */}
                <div
                    class="flex items-center gap-2 text-text-muted text-sm font-medium"
                >
                    <span>{t("blog.published")} {frontmatter.date}</span>
                </div>

                <span class="hidden sm:block text-text-muted">•</span>

                {
                    /* Tiempo estimado de lectura: calculado desde frontmatter.minutesRead */
                }
                <div
                    class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent-bg text-accent-text border border-accent/20 text-xs font-bold uppercase tracking-wide shadow-sm"
                >
                    <span class="icon-[solar--clock-circle-outline] w-3.5 h-3.5"
                    ></span>
                    {Math.ceil(frontmatter.minutesRead || 1)}
                    {t("blog.readTime")}
                </div>
            </div>

            {
                /* Etiquetas: renderizado condicional si frontmatter.tags existe */
            }
            {
                frontmatter.tags && (
                    <div class="flex flex-wrap gap-2">
                        {frontmatter.tags.map((tag) => (
                            <a
                                href={`/${lang === "es" ? "etiquetas" : "en/tags"}/${tag}`}
                                class="text-xs bg-bg-subtle text-text-secondary px-2 py-1 rounded hover:bg-bg-subtle/80 hover:text-text-primary transition no-underline font-medium border border-border-subtle"
                            >
                                #{tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </div>

        {
            /* Contenido principal del post: inyectado desde el archivo .md/.mdx */
        }
        <slot />

        {
            /* Sección de interacción: botones para compartir y formulario de comentarios */
        }
        <ShareButtons title={frontmatter.title} url={Astro.url} />

        <Comments
            slug={frontmatter.ref_id ||
                Astro.url.pathname.replace(/^\/|\/$/g, "").replaceAll("/", "-")}
            lang={lang}
            client:load
        />
    </article>
</Layout>
