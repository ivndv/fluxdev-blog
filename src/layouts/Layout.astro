---
// Layout principal del sitio

// Estilos
import "../styles/global.css";
import "../styles/pagefind.css";
// Componentes
import BaseHead from "../components/layout/BaseHead.astro";
import Search from "../components/layout/Search.jsx";
import ThemeToggle from "../components/layout/ThemeToggle.jsx";
import LanguagePicker from "../components/layout/LanguagePicker.jsx";
import MobileMenuToggle from "../components/layout/MobileMenuToggle.jsx";
// i18n
import { defaultLang, useTranslations } from "../i18n/ui";

// Props con valores por defecto para metadata SEO y configuración de idioma
const {
	title,
	description = "Un blog sobre desarrollo y tecnología.",
	image,
	type = "website",
	publishDate,
	lang = defaultLang,
} = Astro.props;

// Determina idioma actual: prioridad props > params > default
const currentLang = lang || Astro.params.lang || defaultLang;
const t = useTranslations(currentLang as "es" | "en");

// Fuente Outfit con pesos específicos
import "@fontsource/outfit/300.css";
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/700.css";
---

<!doctype html>
<html lang={currentLang}>
    <head>
        {/* BaseHead: meta tags SEO, Open Graph, Twitter Cards y JSON-LD */}
        <BaseHead
            title={title}
            description={description}
            image={image}
            type={type}
            publishDate={publishDate}
        />

        {/* Script de inicialización: tema oscuro y redirección de idioma */}
        <script is:inline>
            // 1. Restaurar tema desde localStorage
            try {
                var _s = JSON.parse(localStorage.getItem("fluxdev-store") || "{}");
                if (_s.state && _s.state.theme === "dark") {
                    document.documentElement.classList.add("dark");
                } else if (_s.state) {
                    document.documentElement.classList.remove("dark");
                } else if (localStorage.getItem("color-theme") === "dark" ||
                    (!("color-theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
                    document.documentElement.classList.add("dark");
                } else {
                    document.documentElement.classList.remove("dark");
                }
            } catch (e) {
                if (localStorage.getItem("color-theme") === "dark" ||
                    (!("color-theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
                    document.documentElement.classList.add("dark");
                }
            }

            // 2. Redirigir a /en/ si el navegador está en inglés
            if (window.location.pathname === "/" && !localStorage.getItem("lang-preference")) {
                var _l = navigator.language || navigator.userLanguage;
                if (_l && _l.startsWith("en")) { window.location.href = "/en/"; }
            }
        </script>

        <!-- Pagefind: buscador estático -->
        <link href="/pagefind/pagefind-ui.css" rel="stylesheet" is:inline />
        <script src="/pagefind/pagefind-ui.js" is:inline></script>
    </head>

    <body
        class="bg-bg-canvas text-text-primary font-light antialiased flex flex-col min-h-screen transition-colors duration-300"
    >
        {/*
      HEADER: Barra de navegación principal
    */}
        <header
            class="border-b border-border-subtle bg-bg-canvas/90 sticky top-0 backdrop-blur-sm z-40 transition-colors duration-300"
        >
            <nav
                class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center gap-4"
            >
                {/* Logo: enlace al home del idioma actual */}
                <a
                    href={`/${currentLang === "es" ? "" : currentLang}`}
                    class="font-bold text-xl tracking-tight hover:text-accent transition-colors shrink-0 flex items-center gap-2.5"
                >
                    <img
                        src="/logo.png"
                        alt="FluxDev Logo"
                        class="w-8 h-8 rounded-lg shadow-sm"
                    />
                    <span>Flux</span>
                </a>

				{/* Bloque central: nav links + buscador */}
				<div class="flex-1 flex justify-center">
					<div class="w-full max-w-3xl flex items-center justify-between">
						<div class="flex-1 max-w-sm">
							<Search client:load />
						</div>
						{/* Enlaces de navegación desktop */}
						<div class="hidden sm:flex items-center gap-4 shrink-0">
							<a
								href={`/${currentLang === "es" ? "" : currentLang}`}
								class="hover:text-accent transition-colors text-sm font-medium"
								>{t("nav.home")}</a
							>
							<a
								href={`/${currentLang === "es" ? "about" : "en/about"}`}
								class="hover:text-accent transition-colors text-sm font-medium"
								>{t("nav.about")}</a
							>
						</div>
					</div>
				</div>

				{/* Controles desktop: selector de tema e idioma */}
				<div class="flex items-center gap-2 shrink-0">
					<div class="hidden sm:flex items-center gap-2">
						<ThemeToggle client:load />
						<LanguagePicker client:load currentPath={Astro.url.pathname} />
					</div>

					<MobileMenuToggle client:load lang={currentLang} />
                </div>
            </nav>
        </header>

        {/*
      MAIN: Contenedor del contenido principal. Slot inyecta la página activa.
    */}
        <main
            class="w-full max-w-3xl mx-auto py-8 sm:py-12 flex-grow animate-fade-in-up"
        >
            <slot />
        </main>

        {/*
      FOOTER: Cuatro columnas en desktop, una en móvil
    */}
        <footer
            class="border-t border-border-subtle mt-auto pt-16 pb-8 transition-colors duration-300"
        >
            <div class="max-w-6xl mx-auto px-4 sm:px-6">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16"
                >
                    {/* Columna 1: Identidad del sitio y enlaces sociales */}
                    <div class="flex flex-col gap-4">
                        <a
                            href={`/${currentLang === "es" ? "" : currentLang}`}
                            class="font-bold text-2xl tracking-tight hover:text-accent transition-colors"
                        >
                            Flux
                        </a>
                        <p
                            class="text-text-secondary text-sm leading-relaxed max-w-xs"
                        >
                            {t("footer.description")}
                        </p>
                        <div class="flex gap-4 mt-2">
                            <a
                                href="https://instagram.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-text-muted hover:text-accent transition-all hover:scale-110 flex items-center"
                                aria-label="Instagram"
                            >
                                <span class="icon-[ri--instagram-line] w-5 h-5"
                                ></span>
                            </a>
                            <a
                                href="https://youtube.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-text-muted hover:text-accent transition-all hover:scale-110 flex items-center"
                                aria-label="YouTube"
                            >
                                <span class="icon-[ri--youtube-fill] w-5 h-5"
                                ></span>
                            </a>
                            <a
                                href="https://github.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-text-muted hover:text-accent transition-all hover:scale-110 flex items-center"
                                aria-label="GitHub"
                            >
                                <span class="icon-[ri--github-fill] w-5 h-5"
                                ></span>
                            </a>
                        </div>
                    </div>

                    {/* Columna 2: Navegación secundaria */}
                    <div class="flex flex-col gap-4">
                        <h3
                            class="font-bold text-text-primary uppercase tracking-wider text-sm"
                        >
                            {t("footer.nav")}
                        </h3>
                        <ul class="flex flex-col gap-3 text-sm text-text-muted">
                            <li>
                                <a
                                    href={`/${currentLang === "es" ? "" : currentLang}`}
                                    class="hover:text-accent transition-colors"
                                    >{t("nav.home")}</a
                                >
                            </li>
                            <li>
                                <a
                                    href={`/${currentLang === "es" ? "about" : "en/about"}`}
                                    class="hover:text-accent transition-colors"
                                    >{t("nav.about")}</a
                                >
                            </li>
                        </ul>
                    </div>

                    {/* Columna 3: Enlaces legales */}
                    <div class="flex flex-col gap-4">
                        <h3
                            class="font-bold text-text-primary uppercase tracking-wider text-sm"
                        >
                            {t("footer.legal")}
                        </h3>
                        <ul class="flex flex-col gap-3 text-sm text-text-muted">
                            <li>
                                <a
                                    href={`/${currentLang === "es" ? "legal/terms" : "en/legal/terms"}`}
                                    class="hover:text-accent transition-colors"
                                    >{t("footer.terms")}</a
                                >
                            </li>
                            <li>
                                <a
                                    href={`/${currentLang === "es" ? "legal/privacy" : "en/legal/privacy"}`}
                                    class="hover:text-accent transition-colors"
                                    >{t("footer.privacy")}</a
                                >
                            </li>
                        </ul>
                    </div>

                    {/* Columna 4: Formulario de suscripción */}
                    <div class="flex flex-col gap-4">
                        <h3
                            class="font-bold text-text-primary uppercase tracking-wider text-sm"
                        >
                            {t("footer.subscribe")}
                        </h3>
                        <form
                            class="flex flex-col gap-3"
                            onsubmit="event.preventDefault();"
                        >
                            <input
                                type="email"
                                placeholder={t("footer.subscribePlaceholder")}
                                class="px-4 py-2 rounded-md border border-border-subtle bg-bg-canvas text-text-primary text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all"
                            />
                            <button
                                type="submit"
                                class="px-4 py-2 rounded-md bg-accent text-text-primary font-medium text-sm hover:bg-accent-hover transition-colors shadow-sm"
                            >
                                {t("footer.subscribeButton")}
                            </button>
                        </form>
                    </div>
                </div>

                {/* Barra inferior: créditos, tecnologías y derechos de autor */}
                <div
                    class="border-t border-border-subtle pt-8 flex flex-col items-center gap-6"
                >
                    <div class="flex flex-col items-center gap-4">
                        <p class="text-sm font-medium text-text-secondary">
                            {t("footer.developedBy")}
                            <span class="font-bold text-text-primary">Sinx</span
                            >
                        </p>
                        <div class="flex flex-wrap justify-center gap-2">
                            {/* Badges de tecnologías */}
                            {
                                ["Astro", "Vite", "Tailwind", "Cloudflare"].map(
                                    (tech) => (
                                        <span class="px-3 py-1 text-xs font-medium rounded-full border border-border-subtle bg-bg-subtle text-text-primary transition-all hover:border-accent hover:text-accent">
                                            {tech}
                                        </span>
                                    ),
                                )
                            }
                        </div>
                    </div>
                    {/* Derechos de autor con año dinámico */}
                    <p class="text-xs text-text-muted">
                        &copy; {new Date().getFullYear()}
                        {t("footer.copyright")}
                        {t("footer.rights")}
                    </p>
                </div>
            </div>
        </footer>
    </body>
</html>
